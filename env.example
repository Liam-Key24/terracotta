# Copy to .env.local and fill in. Production: set all listed below; no defaults are used.

# CRM auth (required in production)
CRM_SECRET=your-long-random-secret-at-least-32-chars
ADMIN_USERNAME=your_admin_username
ADMIN_PASSWORD=your_strong_admin_password
DEVELOPER_PASSWORD=your_developer_password

# Base URL for confirmation/reject links in emails (required for reservations)
NEXT_PUBLIC_BASE_URL=https://your-domain.com

# Owner email that receives reservation emails (required for reservations)
OWNER_EMAIL=reservations@your-domain.com

# SMTP (required for real email in production)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-smtp-email@your-domain.com
SMTP_PASS=your-app-password

# Strongly recommended on Vercel: Upstash Redis (REST) for durable shared state (reservations,
# cancellations, waitlist queue, alternative offers). Without this, /tmp is used and data is not reliable.
# Upstash console → REST API:
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
